project_id = "example-nonprod-project"
region     = "us-central1"
zone       = "us-central1-a"

name_prefix  = "agent-devbox"
network_name = "agent-devbox-vpc"
subnet_name  = "agent-devbox-subnet"
subnet_cidr  = "10.52.0.0/24"

machine_type      = "e2-standard-2"
boot_disk_size_gb = 80
boot_disk_type    = "pd-balanced"

service_account_id = "agent-devbox-vm"

operator_iam_members = [
  # "user:operator@example.com"
]

admin_iam_members = [
  # "user:admin@example.com"
]

# Secret identifiers only. Never place secret payloads, private keys, or tokens here.
secret_manager_secret_refs = [
  # "github-app-private-key-placeholder",
]

# Stage 5 GitHub App integration. Keep disabled until the GitHub App is
# manually created, installed only on the approved disposable repository, and
# the private key PEM is stored in Secret Manager.
github_app_integration_enabled    = false
github_app_id                     = null
github_app_installation_id        = null
github_app_private_key_secret_ref = null
github_repository_owner           = "DimitryZH"
github_repository_name            = "application-modernization-lab"

# Stage 6 project registration. Enable only after the managed Gateway,
# OpenAI OAuth model access, and scoped GitHub App broker have passed validation.
stage6_project_registration_enabled = false
stage6_project_name                 = "application-modernization-lab"
stage6_project_slug                 = "application-modernization-lab"
stage6_base_branch                  = "main"
stage6_channel_id                   = "openclaw-control-ui-main"

artifact_registry_reader_enabled = false
# artifact_registry_project_id    = "example-nonprod-project"
# artifact_registry_location      = "us-central1"
# artifact_registry_repository_id = "example-repository"

deletion_protection = false
dotnet_sdk_channel   = "10.0"
nodejs_major_version = 22

# Enables IAM only. It does not install or configure the Google Cloud Ops Agent.
observability_iam_enabled = false

labels = {
  owner       = "platform"
  environment = "experiment"
}
