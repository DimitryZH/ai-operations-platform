#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

log() {
  printf '[agent-devbox-bootstrap] %s\n' "$*"
}

fail() {
  log "ERROR: $*"
  exit 1
}

[[ "$EUID" -eq 0 ]] || fail "Startup script must run as root."

DOTNET_SDK_CHANNEL="${dotnet_sdk_channel}"
NODEJS_MAJOR_VERSION="${nodejs_major_version}"

dotnet_channel_installed() {
  command -v dotnet >/dev/null 2>&1 || return 1
  local channel_pattern="$${DOTNET_SDK_CHANNEL//./\\.}"
  dotnet --list-sdks | awk '{print $1}' | grep -Eq "^$channel_pattern\\."
}

export DEBIAN_FRONTEND=noninteractive
rm -f /var/lib/devclaw/bootstrap-ready

log "Installing base packages"
apt-get update
apt-get install -y --no-install-recommends \
  apt-transport-https \
  build-essential \
  ca-certificates \
  curl \
  git \
  gnupg \
  jq \
  lsb-release \
  software-properties-common \
  unzip

install -m 0755 -d /etc/apt/keyrings
. /etc/os-release
ARCH="$(dpkg --print-architecture)"

if ! command -v docker >/dev/null 2>&1; then
  log "Installing Docker Engine and Compose plugin"
  curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /etc/apt/keyrings/docker.asc
  chmod a+r /etc/apt/keyrings/docker.asc
  printf 'deb [arch=%s signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/ubuntu %s stable\n' \
    "$ARCH" "$VERSION_CODENAME" > /etc/apt/sources.list.d/docker.list
  apt-get update
  apt-get install -y --no-install-recommends \
    containerd.io \
    docker-buildx-plugin \
    docker-ce \
    docker-ce-cli \
    docker-compose-plugin
fi
systemctl enable --now docker.service

if ! command -v gh >/dev/null 2>&1; then
  log "Installing GitHub CLI binary without authentication"
  curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    -o /etc/apt/keyrings/githubcli-archive-keyring.gpg
  chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg
  printf 'deb [arch=%s signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main\n' \
    "$ARCH" > /etc/apt/sources.list.d/github-cli.list
  apt-get update
  apt-get install -y --no-install-recommends gh
fi

if ! dotnet_channel_installed; then
  log "Installing .NET SDK $DOTNET_SDK_CHANNEL"
  apt-get update
  apt-cache show "dotnet-sdk-$DOTNET_SDK_CHANNEL" >/dev/null 2>&1 ||
    fail "Ubuntu APT package dotnet-sdk-$DOTNET_SDK_CHANNEL is unavailable."
  apt-get install -y --no-install-recommends "dotnet-sdk-$DOTNET_SDK_CHANNEL"
fi

if ! command -v node >/dev/null 2>&1 || [[ "$(node -p 'Number(process.versions.node.split(".")[0])')" -lt "$NODEJS_MAJOR_VERSION" ]]; then
  log "Installing Node.js $NODEJS_MAJOR_VERSION"
  curl -fsSL "https://deb.nodesource.com/setup_$NODEJS_MAJOR_VERSION.x" | bash -
  apt-get install -y --no-install-recommends nodejs
fi

for user_name in devclaw-svc devclaw-token devclaw-validate; do
  if ! id -u "$user_name" >/dev/null 2>&1; then
    useradd --system --create-home --shell /bin/bash "$user_name"
  fi
done

if ! getent group devclaw-broker >/dev/null; then
  groupadd --system devclaw-broker
fi

usermod -aG docker devclaw-svc
usermod -aG devclaw-broker devclaw-svc
usermod -aG devclaw-broker devclaw-token
if id -nG devclaw-token | tr ' ' '\n' | grep -qx docker; then
  gpasswd -d devclaw-token docker
fi
if id -nG devclaw-validate | tr ' ' '\n' | grep -qx docker; then
  gpasswd -d devclaw-validate docker
fi
if id -nG devclaw-validate | tr ' ' '\n' | grep -qx devclaw-broker; then
  gpasswd -d devclaw-validate devclaw-broker
fi

log "Creating base directories"
install -d -o root -g devclaw-svc -m 0750 /opt/devclaw
install -d -o root -g devclaw-svc -m 0750 /opt/devclaw/runtime
install -d -o root -g devclaw-svc -m 0750 /opt/devclaw/config
install -d -o root -g devclaw-svc -m 0750 /opt/devclaw/prompts
install -d -o root -g devclaw-svc -m 0750 /opt/devclaw/bin

install -d -o devclaw-svc -g devclaw-svc -m 0750 /var/lib/devclaw
install -d -o devclaw-svc -g devclaw-svc -m 0750 /var/lib/devclaw/projects
install -d -o devclaw-svc -g devclaw-svc -m 0750 /var/lib/devclaw/sessions
install -d -o devclaw-svc -g devclaw-svc -m 0750 /var/lib/devclaw/audit
install -d -o root -g devclaw-broker -m 0750 /var/lib/devclaw/gateway

install -d -o devclaw-svc -g devclaw-svc -m 0750 /workspace
install -d -o devclaw-svc -g devclaw-svc -m 0750 /workspace/repos
install -d -o devclaw-svc -g devclaw-svc -m 0750 /workspace/worktrees
install -d -o devclaw-svc -g devclaw-svc -m 0750 /workspace/evidence

install -d -o devclaw-svc -g devclaw-svc -m 0750 /var/cache/devclaw-experiment
install -d -o devclaw-svc -g devclaw-svc -m 0750 /var/cache/devclaw-experiment/docker
install -d -o devclaw-svc -g devclaw-svc -m 0750 /var/cache/devclaw-experiment/nuget
install -d -o devclaw-svc -g devclaw-svc -m 0750 /var/cache/devclaw-experiment/dotnet
install -d -o root -g devclaw-svc -m 0750 /var/cache/devclaw-experiment/devclaw-compat

install -d -o devclaw-token -g devclaw-token -m 0700 /run/secrets/devclaw
install -d -o devclaw-token -g devclaw-broker -m 0750 /run/devclaw

cat > /opt/devclaw/config/bootstrap-validation.env <<EOF
EXPECTED_DOTNET_SDK_CHANNEL=$DOTNET_SDK_CHANNEL
EXPECTED_NODEJS_MAJOR=$NODEJS_MAJOR_VERSION
EOF
chown root:devclaw-svc /opt/devclaw/config/bootstrap-validation.env
chmod 0640 /opt/devclaw/config/bootstrap-validation.env

printf '%s' '${validation_tools_b64}' | base64 -d > /opt/devclaw/bin/validate-tools.sh
printf '%s' '${validation_runtime_b64}' | base64 -d > /opt/devclaw/bin/validate-runtime.sh
printf '%s' '${validation_openclaw_b64}' | base64 -d > /opt/devclaw/bin/validate-openclaw-devclaw.sh
printf '%s' '${runtime_install_b64}' | base64 -d > /opt/devclaw/bin/install-openclaw-devclaw.sh
printf '%s' '${gateway_install_b64}' | base64 -d > /opt/devclaw/bin/install-openclaw-gateway-service.sh
printf '%s' '${gateway_validate_b64}' | base64 -d > /opt/devclaw/bin/validate-openclaw-gateway.sh
printf '%s' '${devclaw_compat_build_b64}' | base64 -d > /opt/devclaw/bin/build-devclaw-compat-package.sh
printf '%s' '${devclaw_compat_validate_b64}' | base64 -d > /opt/devclaw/bin/validate-devclaw-compat-package.sh
printf '%s' '${runtime_versions_b64}' | base64 -d > /opt/devclaw/config/versions.env
printf '%s' '${devclaw_compat_overlay_b64}' | base64 -d > /opt/devclaw/config/devclaw-manifest-overlay.json
chown root:devclaw-svc \
  /opt/devclaw/bin/validate-tools.sh \
  /opt/devclaw/bin/validate-runtime.sh \
  /opt/devclaw/bin/validate-openclaw-devclaw.sh \
  /opt/devclaw/bin/install-openclaw-devclaw.sh \
  /opt/devclaw/bin/install-openclaw-gateway-service.sh \
  /opt/devclaw/bin/validate-openclaw-gateway.sh \
  /opt/devclaw/bin/build-devclaw-compat-package.sh \
  /opt/devclaw/bin/validate-devclaw-compat-package.sh
chmod 0750 \
  /opt/devclaw/bin/validate-tools.sh \
  /opt/devclaw/bin/validate-runtime.sh \
  /opt/devclaw/bin/validate-openclaw-devclaw.sh \
  /opt/devclaw/bin/install-openclaw-devclaw.sh \
  /opt/devclaw/bin/install-openclaw-gateway-service.sh \
  /opt/devclaw/bin/validate-openclaw-gateway.sh \
  /opt/devclaw/bin/build-devclaw-compat-package.sh \
  /opt/devclaw/bin/validate-devclaw-compat-package.sh
chown root:devclaw-svc \
  /opt/devclaw/config/versions.env \
  /opt/devclaw/config/devclaw-manifest-overlay.json
chmod 0640 \
  /opt/devclaw/config/versions.env \
  /opt/devclaw/config/devclaw-manifest-overlay.json

/opt/devclaw/bin/validate-tools.sh
REQUIRE_BOOTSTRAP_MARKER=false /opt/devclaw/bin/validate-runtime.sh

marker_tmp="$(mktemp /var/lib/devclaw/.bootstrap-ready.XXXXXX)"
cat > "$marker_tmp" <<EOF
base_prerequisites=installed
base_validation=passed
EOF
chown devclaw-svc:devclaw-svc "$marker_tmp"
chmod 0640 "$marker_tmp"
mv -f "$marker_tmp" /var/lib/devclaw/bootstrap-ready

log "Base prerequisite bootstrap complete."
