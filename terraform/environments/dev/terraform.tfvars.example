project_id = "your-gcp-project-id"
region     = "us-central1"

artifact_repository_id      = "ai-agent-runtime"
runtime_service_account_id  = "cloudrun-runtime"
runtime_secret_id           = "ai-runtime-config"
cloud_run_service_name      = "ai-agent-runtime"
cloud_run_container_image   = "us-central1-docker.pkg.dev/your-gcp-project-id/ai-agent-runtime/ai-agent-runtime:replace-me"
cloud_run_min_instances     = 0
cloud_run_max_instances     = 3
cloud_run_deletion_protection = false

# DEV-ONLY: keep false for secure default posture.
allow_unauthenticated = false

labels = {
  project = "ai-agent-host"
  env     = "dev"
}
